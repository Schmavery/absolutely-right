{
  "name": "extra-thinking",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "validate-data": "vitest run tests/validateData.test.ts",
    "check": "npm run typecheck && npm run validate-data",
    "prepare": "git config core.hooksPath .githooks",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:launch": "RUN_LAUNCH_BENCH=1 vitest run tests/launchBench.test.ts",
    "bench:phase2": "RUN_PHASE2_BENCH=1 vitest run tests/launchBench.test.ts -t \"phase 2\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "handlebars": "^4.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.6.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
